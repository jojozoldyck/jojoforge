const [showGrid, setShowGrid] = useState(false);
const playRef = useRef(null);
const tickRef = useRef(0);

// Advance all enabled slots together
useEffect(() => {
clearInterval(playRef.current);
if (!playing) return;
playRef.current = setInterval(() => {
tickRef.current++;
setSlots(prev => {
const next = { …prev };
CATS.forEach(cat => {
if (!next[cat].enabled) return;
const total = next[cat].frames.length;
if (total > 1) next[cat] = { …next[cat], activeFrame: tickRef.current % total };
});
return next;
});
}, 1000 / fps);
return () => clearInterval(playRef.current);
}, [playing, fps]);

// Render composite canvas
useEffect(() => {
const canvas = canvasRef.current; if (!canvas) return;
// Find max dimensions
const maxW = Math.max(…CATS.map(c => slots[c].fw));
const maxH = Math.max(…CATS.map(c => slots[c].fh));
canvas.width = maxW * scale;
canvas.height = maxH * scale;
const ctx = canvas.getContext(“2d”);
ctx.clearRect(0, 0, canvas.width, canvas.height);

