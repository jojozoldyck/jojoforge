// ── Helpers ───────────────────────────────────────────────────────────────────
const blank   = (w=SW,h=SH) => new Uint8ClampedArray(w*h*4);
const clonePx = a => new Uint8ClampedArray(a);
const hex2rgb = h => [parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)];
const rgb2hex = (r,g,b) => “#”+[r,g,b].map(v=>v.toString(16).padStart(2,“0”)).join(””);
const colDist = (r1,g1,b1,r2,g2,b2) => Math.sqrt((r1-r2)**2+(g1-g2)**2+(b1-b2)**2);

function putPx(res,x,y,rgba,fw,fh){
if(x<0||x>=fw||y<0||y>=fh) return;
const i=(y*fw+x)*4; res[i]=rgba[0];res[i+1]=rgba[1];res[i+2]=rgba[2];res[i+3]=rgba[3];
}

function floodFill(px,x,y,[fr,fg,fb],fw,fh){
const i=(y*fw+x)*4,[tr,tg,tb,ta]=[px[i],px[i+1],px[i+2],px[i+3]];
if(tr===fr&&tg===fg&&tb===fb&&ta===255) return px;
const res=clonePx(px),stack=[[x,y]],seen=new Set();
while(stack.length){
const [cx,cy]=stack.pop();
if(cx<0||cx>=fw||cy<0||cy>=fh) continue;
const k=cy*fw+cx; if(seen.has(k)) continue;
const ci=k*4;
if(res[ci]!==tr||res[ci+1]!==tg||res[ci+2]!==tb||res[ci+3]!==ta) continue;
seen.add(k); res[ci]=fr;res[ci+1]=fg;res[ci+2]=fb;res[ci+3]=255;
stack.push([cx+1,cy],[cx-1,cy],[cx,cy+1],[cx,cy-1]);
}
return res;
}

function drawLine(px,x0,y0,x1,y1,rgba,fw,fh){
const res=clonePx(px);
const dx=Math.abs(x1-x0),dy=Math.abs(y1-y0),sx=x0<x1?1:-1,sy=y0<y1?1:-1;
let err=dx-dy,x=x0,y=y0;
for(let i=0;i<10000;i++){
putPx(res,x,y,rgba,fw,fh);
if(x===x1&&y===y1) break;
const e2=2*err; if(e2>-dy){err-=dy;x+=sx;} if(e2<dx){err+=dx;y+=sy;}
}
return res;
}

function drawRect(px,x0,y0,x1,y1,rgba,filled,fw,fh){
const res=clonePx(px);
const minX=Math.min(x0,x1),maxX=Math.max(x0,x1),minY=Math.min(y0,y1),maxY=Math.max(y0,y1);
for(let y=minY;y<=maxY;y++) for(let x=minX;x<=maxX;x++){
if(filled||x===minX||x===maxX||y===minY||y===maxY) putPx(res,x,y,rgba,fw,fh);
}
return res;
}

function drawEllipse(px,x0,y0,x1,y1,rgba,filled,fw,fh){
const res=clonePx(px);
const cx=(x0+x1)/2,cy=(y0+y1)/2,rx=Math.abs(x1-x0)/2,ry=Math.abs(y1-y0)/2;
if(rx<1||ry<1) return res;
const steps=Math.max(rx,ry)*4;
const pts=new Set();
for(let i=0;i<=steps;i++){
const a=(i/steps)*2*Math.PI;
const px2=Math.round(cx+rx*Math.cos(a)),py=Math.round(cy+ry*Math.sin(a));
pts.add(`${px2},${py}`); putPx(res,px2,py,rgba,fw,fh);
}
if(filled){
for(let y=Math.ceil(cy-ry);y<=Math.floor(cy+ry);y++){
const dy2=(y-cy)/ry, dx2=Math.sqrt(Math.max(0,1-dy2*dy2))*rx;
for(let x=Math.ceil(cx-dx2);x<=Math.floor(cx+dx2);x++) putPx(res,x,y,rgba,fw,fh);
}
}
return res;
}

function drawTriangle(px,x0,y0,x1,y1,rgba,filled,fw,fh){
const res=clonePx(px);
// Isoceles: top center, bottom-left, bottom-right
const tx=Math.round((x0+x1)/2),ty=y0,bl={x:x0,y:y1},br={x:x1,y:y1};
const lineInto=(r,ax,ay,bx,by)=>{ const dx=Math.abs(bx-ax),dy=Math.abs(by-ay),sx=ax<bx?1:-1,sy=ay<by?1:-1; let err=dx-dy,x=ax,y=ay; for(let i=0;i<10000;i++){putPx(r,x,y,rgba,fw,fh);if(x===bx&&y===by)break;const e2=2*err;if(e2>-dy){err-=dy;x+=sx;}if(e2<dx){err+=dx;y+=sy;}} };
if(filled){
const minY=Math.min(ty,y1),maxY=Math.max(ty,y1);
for(let y=minY;y<=maxY;y++){
const t=(y-ty)/(y1-ty||1);
const lx=Math.round(tx+(x0-tx)*t),rx2=Math.round(tx+(x1-tx)*t);
for(let x=Math.min(lx,rx2);x<=Math.max(lx,rx2);x++) putPx(res,x,y,rgba,fw,fh);
}
} else {
lineInto(res,tx,ty,bl.x,bl.y); lineInto(res,bl.x,bl.y,br.x,br.y); lineInto(res,br.x,br.y,tx,ty);
}
return res;
}

function autoOutline(px,outlineRgba,fw,fh){
const res=clonePx(px);
for(let y=0;y<fh;y++) for(let x=0;x<fw;x++){
const i=(y*fw+x)*4;
if(px[i+3]>0) continue; // skip non-transparent
const neighbors=[[x-1,y],[x+1,y],[x,y-1],[x,y+1]];
if(neighbors.some(([nx,ny])=>nx>=0&&nx<fw&&ny>=0&&ny<fh&&px[(ny*fw+nx)*4+3]>0)){
res[i]=outlineRgba[0];res[i+1]=outlineRgba[1];res[i+2]=outlineRgba[2];res[i+3]=255;
}
}
return res;
}

function flipH(px,fw,fh){
const res=clonePx(px);
for(let y=0;y<fh;y++) for(let x=0;x<Math.floor(fw/2);x++){
const a=(y*fw+x)*4,b=(y*fw+(fw-1-x))*4;
for(let c=0;c<4;c++){const t=res[a+c];res[a+c]=res[b+c];res[b+c]=t;}
}
return res;
}

function flipV(px,fw,fh){
const res=clonePx(px);
for(let y=0;y<Math.floor(fh/2);y++) for(let x=0;x<fw;x++){
const a=(y*fw+x)*4,b=((fh-1-y)*fw+x)*4;
for(let c=0;c<4;c++){const t=res[a+c];res[a+c]=res[b+c];res[b+c]=t;}
}
return res;
}

function rotate90(px,fw,fh){
// CW 90: new[x][y] = old[fh-1-y][x], new dims = fh x fw
const res=new Uint8ClampedArray(fw*fh*4);
for(let y=0;y<fh;y++) for(let x=0;x<fw;x++){
const src=(y*fw+x)*4, dst=(x*fh+(fh-1-y))*4;
res[dst]=px[src];res[dst+1]=px[src+1];res[dst+2]=px[src+2];res[dst+3]=px[src+3];
}
return res; // dims swapped: fh x fw
}

function makeCat(){
return {clips:[{id:“c0”,name:“idle”}],activeClip:0,activeFrame:0,activeLayer:0,
frames:[[{id:“l0”,name:“Layer 1”,visible:true,locked:false,px:blank()}]]};
}

function drawLayers(ctx,layers,scale=1,fw=SW,fh=SH){
layers.forEach(l=>{
if(!l.visible) return;
const aw=l.fw||fw, ah=l.fh||fh;
const tmp=document.createElement(“canvas”); tmp.width=aw; tmp.height=ah;
tmp.getContext(“2d”).putImageData(new ImageData(new Uint8ClampedArray(l.px),aw,ah),0,0);
ctx.imageSmoothingEnabled=false;
ctx.drawImage(tmp,0,0,aw*scale,ah*scale);
});
}

