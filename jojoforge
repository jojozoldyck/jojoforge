const paintAt = (px,x,y,rgba,fw2=fw(),fh2=fh())=>{
const res=clonePx(px),sz=brushRef.current;
const aa=aaRef.current;
for(let dy=0;dy<sz;dy++) for(let dx=0;dx<sz;dx++){
if(aa>0&&sz>1){
// soft brush edges with aa
const dist=Math.sqrt((dx-sz/2+0.5)**2+(dy-sz/2+0.5)**2)/(sz/2);
const alpha=Math.max(0,Math.min(1,1-dist)*(1-aa*0.7));
const blended=[rgba[0],rgba[1],rgba[2],Math.round(rgba[3]*alpha)];
putPx(res,x+dx,y+dy,blended,fw2,fh2);
if(symRef.current) putPx(res,fw2-1-x-dx,y+dy,blended,fw2,fh2);
} else {
putPx(res,x+dx,y+dy,rgba,fw2,fh2);
if(symRef.current) putPx(res,fw2-1-x-dx,y+dy,rgba,fw2,fh2);
}
}
return res;
};

const interpolate=(x0,y0,x1,y1,rgba,startPx,fw2=fw(),fh2=fh())=>{
let px=clonePx(startPx);
const dx=Math.abs(x1-x0),dy=Math.abs(y1-y0),sx=x0<x1?1:-1,sy=y0<y1?1:-1;
let err=dx-dy,x=x0,y=y0;
for(let i=0;i<10000;i++){
px=paintAt(px,x,y,rgba,fw2,fh2); if(x===x1&&y===y1) break;
const e2=2*err; if(e2>-dy){err-=dy;x+=sx;} if(e2<dx){err+=dx;y+=sy;}
}
return px;
};

