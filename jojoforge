let nr,ng2,nb;
switch(i6%6){case 0:nr=v;ng2=t2;nb=p;break;case 1:nr=q;ng2=v;nb=p;break;case 2:nr=p;ng2=v;nb=t2;break;case 3:nr=p;ng2=q;nb=v;break;case 4:nr=t2;ng2=p;nb=v;break;default:nr=v;ng2=p;nb=q;}
res[i]=Math.round(nr*255);res[i+1]=Math.round(ng2*255);res[i+2]=Math.round(nb*255);
}
