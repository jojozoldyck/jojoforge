const canvasRef = useRef(null);
// Per-slot: { frames: […pixels], activeFrame: 0, fw, fh, name }
const [slots, setSlots] = useState(() =>
CATS.reduce((acc, cat) => {
const d = dataRef.current[cat];
return { …acc, [cat]: {
frames: d.frames.map(fl => fl.filter(l => l.visible).reduce((out, l) => {
const fw = l.fw || d.fw || 64, fh = l.fh || d.fh || 64;
const res = out || new Uint8ClampedArray(fw * fh * 4);
// composite layers
for (let i = 0; i < res.length; i += 4) {
const a = l.px[i+3] / 255;
if (a > 0) {
res[i]   = Math.round(l.px[i]   * a + res[i]   * (1-a));
res[i+1] = Math.round(l.px[i+1] * a + res[i+1] * (1-a));
res[i+2] = Math.round(l.px[i+2] * a + res[i+2] * (1-a));
res[i+3] = Math.min(255, res[i+3] + l.px[i+3]);
}
}
return res;
}, null) || new Uint8ClampedArray((d.fw||64)*(d.fh||64)*4)),
activeFrame: d.activeFrame,
fw: d.fw || 64,
fh: d.fh || 64,
enabled: true,
}};
}, {})
);
const [playing, setPlaying] = useState(false);
const [fps, setFps] = useState(8);
const [scale, setScale] = useState(4);
